{% set divClass = options.divClass ?? 'inline-block mt-4 mr-4' %}
{% set divWrapper = option.divWrapper ?? false %}

{% if divWrapper %}
<div class="{{ divClass }}">
{% endif %}
  {% if "Anchor" in cta.type|split("hyper")|last %}
    <a href="{{ cta.linkValue }}" target="{{ cta.target }}" class="{{ classes }}">{{ cta.text }}</a>
  {% else %}
    {{ cta.getLink({ class: classes}) }}
  {% endif %}
{% if divWrapper %}
</div>
{% endif %}
