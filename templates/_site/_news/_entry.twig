{% extends '_site/_layout' %}

{% set overview = craft.entries.section('newsOverview').one() %}
{% set breadcrumbs = [
    overview,
    entry,
] %}

{% block content %}

    {% do seoFields.setPageType('NewsArticle') %}
    {% do seoFields.graph.newsArticle()
        .headline(entry.title)
        .articleSection(overview.title ?? null)
        .description(entry.intro|striptags|trim)
        .url(entry.url)
        .datePublished(entry.postDate|atom)
        .dateModified(entry.dateUpdated|atom)
        .image(entry.overviewImage.one() ? entry.overviewImage.one().url : null)
    %}

    {% embed "_site/_snippet/_content/_defaultHeader" %}
        {% block headerText %}
            {% include '_site/_snippet/_nav/_breadcrumb' %}
            {% include '_site/_snippet/_content/_pageTitle' %}
            <div class="mb-5 text-sm font-semibold text-gray-700">{{ entry.postDate|date('d.m.Y'|t) }}</div>
            {% include '_site/_snippet/_content/_intro' %}
        {% endblock %}
    {% endembed %}

     {% include '_site/_snippet/_content/_contentBuilder'
        with {
        settings : {
            section: 'section',
            container: 'container',
        }
    } %}

    <div class="section section--default">
        <div class="container">
            {% include '_site/_snippet/_content/_socialShare' %}
        </div>
    </div>
{% endblock %}