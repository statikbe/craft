{% extends "_site/_layout.twig" %}

{% set breadcrumbs = entry.ancestors().all()|merge([entry]) %}

{% block content %}

    {% set q = craft.app.request.getParam('q') %}
    {% set q = q is valid_query ? q : '' %}

    {% embed "_site/_snippet/_content/_defaultHeader" %}
        {% block headerText %}
            {% include '_site/_snippet/_nav/_breadcrumb' %}
            {% include '_site/_snippet/_content/_pageTitle' %}
            {% if q|length %}
                <div class="text-xl font-light text-editor">
                    {{ 'Resultaten voor'|t }} "{{ q }}"
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
    <div class="section section--default">
        <div class="container">
            <div class="w-full md:w-2/3">
                <div class="p-6 bg-light">
                    {% include '_site/_snippet/_global/_search' with {showInline: true, filledInValue: q|length ? q : false} %}
                </div>
            </div>
        </div>
    </div>

    {% if q|length %}
        {% set results = craft.entries.search('*' ~ q ~ '*').uri(':notempty:').section(['not', 'systemOffline', 'pageNotFound', 'cookiePolicy', 'privacyPolicy', 'searchResults']).orderBy('score') %}
        <div class="section section--default" id="results">
            <div class="container">
                <div class="w-full md:w-2/3">
                    {% if results.collect()|length %}
                        {% paginate results.limit(12) as loadPageInfo, loadEntries %}
                        <div class="space-y-6"
                            data-load-more="searchResults"
                            data-load-more-pagination="pagination"
                            data-load-more-loader="paginationLoader"
                            data-load-more-trigger="loadMoreTrigger"
                            data-load-more-infinite-scroll="false">
                            {% for resultEntry in loadEntries %}
                                <div class="bg-light rounded p-10 relative group">
                                    <span class="text-xl text-black">{{ resultEntry.section.name | t }}</span>
                                    <h3 class="mb-1 hover-underline">
                                        <a href="{{ resultEntry.getUrl() }}" class="link--extended">
                                            {{ resultEntry.overviewTitle ?? resultEntry.title }}
                                        </a>
                                    </h3>
                                    <div class="text-sm underline text-black group-hover:no-underline">{{ resultEntry.getUrl() }}</div>
                                    <div class="mt-2">
                                        {{ resultEntry.overviewDescription ?? (resultEntry.intro ?? '')|striptags|truncate(280)|raw }}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="flex justify-center mt-8" id="pagination">
                            <div class="hidden" id="paginationLoader">
                                {% include '_site/_snippet/_item/_loader' %}
                                <div class="mt-2 italic opacity-50">{{ "Meer items aan het laden"|t }}</div>
                            </div>
                            {% if loadPageInfo.nextUrl %}
                                <a href="{{ loadPageInfo.nextUrl }}" class="btn btn--ghost" id="loadMoreTrigger"
                                   data-load-wrapper="results">{{ "Meer resultaten laden"|t }}</a>
                            {% endif %}
                        </div>
                    {% else %}
                        {% if entry.contentBuilder.collect()|length %}
                            {% include '_site/_snippet/_content/_contentBuilder' %}
                        {% else %}
                            <div>{{ "Helaas! We konden geen resultaten vinden voor uw zoekopdracht."|t }}</div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="section section--default">
            <div class="container">
                <div class="text-center">
                    {{ 'Type something in the search bar to find results.'|t }}
                </div>
            </div>
        </div>
    {% endif %}

{% endblock %}
